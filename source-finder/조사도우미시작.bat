@echo off
chcp 65001 >nul
title 원본 조사 도우미 서버

:: 8787 포트 중복 실행 확인
netstat -ano | findstr :8787 >nul
if %errorlevel% equ 0 (
    echo ==================================================================
    echo [안내] 원본 조사 도우미가 이미 켜져 있습니다.
    echo 이 창은 안전하게 닫으셔도 됩니다.
    echo ==================================================================
    pause
    exit
)

echo ==================================================================
echo [시스템] 원본 조사 도우미 서버를 시작합니다...
echo ==================================================================
cd /d "%~dp0"
cd ..
node source-finder/helper_server.mjs
pause
